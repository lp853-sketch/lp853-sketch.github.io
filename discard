                    transparent,
                    transparent 35px,
                    rgba(212, 175, 55, 0.03) 35px,
                    rgba(212, 175, 55, 0.03) 70px
                );
            pointer-events: none;
            z-index: 1;
        }
nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(10, 26, 58, 0.95);
